# Existing application secrets
OPENAI_API_KEY=
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# Public application URL. Use a tunnel while testing callbacks, then your domain.
APP_BASE_URL=http://localhost:3000

# PayPlus sandbox credentials
PAYPLUS_SANDBOX=true
PAYPLUS_API_KEY=
PAYPLUS_SECRET_KEY=
PAYPLUS_PAYMENT_PAGE_UID=
PAYPLUS_TERMINAL_UID=
# Generate a long random value; do not reuse an API key.
PAYPLUS_REFERENCE_SECRET=

# Firebase Console > Project settings > Service accounts > Generate new private key
# Paste the complete downloaded JSON on one line.
FIREBASE_SERVICE_ACCOUNT_JSON=
